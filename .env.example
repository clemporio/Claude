# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_INVITE_LINK=https://discord.gg/your_invite_code
DISCORD_SERVER_NAME=Your Server Name
DISCORD_SERVER_DESCRIPTION=A short description of what your server is about.

# Twitter/X API (v2)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Reddit API
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=DiscordPromoBot/1.0

# Targeting
TARGET_KEYWORDS=gaming,community,chat,hangout
TARGET_MIN_ENGAGEMENT=10
TARGET_MAX_POSTS_PER_HOUR=5
