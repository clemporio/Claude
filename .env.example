# Reddit API (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=scout-bot/1.0

# Twitter/X API (https://developer.twitter.com)
# Bearer token = read-only (monitoring). User tokens = read+write (posting).
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Discord invite links (create per-platform invites in Discord server settings)
DISCORD_INVITE_REDDIT=
DISCORD_INVITE_TWITTER=
DISCORD_INVITE_FORUMS=
DISCORD_INVITE_DEFAULT=https://discord.gg/nVNAAWyv

# Scan intervals (minutes)
REDDIT_SCAN_INTERVAL=30
TWITTER_SCAN_INTERVAL=15
FORUM_SCAN_INTERVAL=60

# Scoring thresholds
RELEVANCE_THRESHOLD=50
OPPORTUNITY_THRESHOLD=40

# Draft expiry (hours)
DRAFT_EXPIRY_HOURS=12

# Safety rails — DO NOT remove these, they protect your accounts
SAFETY_MAX_POSTS_PER_DAY=8
SAFETY_MAX_REDDIT_PER_DAY=4
SAFETY_MAX_TWITTER_PER_DAY=5
SAFETY_MAX_FORUM_PER_DAY=2
SAFETY_DISCORD_MENTION_RATIO=4
SAFETY_REDDIT_COOLDOWN_MIN=90
SAFETY_TWITTER_COOLDOWN_MIN=45
SAFETY_FORUM_COOLDOWN_MIN=120
SAFETY_MAX_PER_SUBREDDIT=1
SAFETY_SUBREDDIT_COOLDOWN_HR=24
